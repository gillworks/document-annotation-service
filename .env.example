# Required when ANNOTATOR_PROVIDER=openai and ANNOTATOR_MODE is not mock.
OPENAI_API_KEY=

# Required when ANNOTATOR_PROVIDER=anthropic and ANNOTATOR_MODE is not mock.
ANTHROPIC_API_KEY=

# single_call | agent | mock
# Use "mock" to exercise uploads/status without a provider key during local review.
# Use "agent" for LangGraph-backed cited annotations.
ANNOTATOR_MODE=single_call

# openai | anthropic
ANNOTATOR_PROVIDER=openai

# Model selection for the configured provider.
ANNOTATOR_MODEL=gpt-4o-mini

# Comma-separated list of origins allowed by CORS middleware.
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Optional overrides.
# DATABASE_URL=postgresql+psycopg://annotations:annotations@db:5432/annotations
# UPLOAD_DIR=/data/uploads
# MAX_FILE_SIZE_BYTES=26214400
# LLM_TIMEOUT_SECONDS=60
# INPUT_TOKEN_COST_PER_1M=0
# OUTPUT_TOKEN_COST_PER_1M=0
# WORKER_POLL_INTERVAL_SECONDS=1
# WORKER_SWEEP_INTERVAL_SECONDS=30
# WORKER_STALE_AFTER_SECONDS=600
